# Configuración del microservicio RETHUS (copiar a .env y ajustar)

# URL de la Consulta de Ciudadanos en RETHUS (pública, sin login). Confirmada.
RETHUS_CONSULTA_URL=https://web.sispro.gov.co/THS/Cliente/ConsultasPublicas/ConsultaPublicaDeTHxIdentificacion.aspx

# Segundos que vive una sesión de scraping entre /iniciar y /validar.
SESSION_TTL_SECONDS=180

# Navegador headless (false para depurar viendo el navegador).
PLAYWRIGHT_HEADLESS=true

# Timeout de navegación / espera de selectores (ms).
NAV_TIMEOUT_MS=30000
